{
  "name": "audit-risk",
  "displayName": "audit-risk",
  "description": "AI 编码风控平台 — 在 VS Code 里直接看到 audit-risk 的风险审查结果",
  "version": "0.1.0",
  "publisher": "audit-risk",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "auditRisk.check",
        "title": "audit-risk: 审查当前工作区",
        "category": "audit-risk"
      },
      {
        "command": "auditRisk.clear",
        "title": "audit-risk: 清除审查结果",
        "category": "audit-risk"
      }
    ],
    "configuration": {
      "title": "audit-risk",
      "properties": {
        "auditRisk.binaryPath": {
          "type": "string",
          "default": "",
          "description": "audit-risk 可执行文件的绝对路径。留空则在 PATH 中查找 `audit-risk`。"
        },
        "auditRisk.runOnSave": {
          "type": "boolean",
          "default": false,
          "description": "保存文件时自动运行 audit-risk 审查（可能较慢，取决于项目大小）。"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "typescript": "^5.4.0"
  }
}
