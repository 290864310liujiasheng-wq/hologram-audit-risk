# HoloGram — environment variables
# Copy this file to .env and fill in your values. .env is git-ignored.

# === LLM Provider (Anthropic / OpenAI-compatible) ===
# Required for the built-in Agent. At least one provider must be configured.
LLM_PROVIDER=anthropic
# LLM_PROVIDER=openai

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=

# OpenAI-compatible
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=

# === MCP (Matrix Communication Protocol) ===
# MCP_LISTEN_PORT=9876
# MCP_AUTO_START=false

# === Entitlement Signing (Auth Server only) ===
# Ed25519 private key used by the auth server to sign customer entitlements.
# The matching public key is embedded in the CLI binary (ENTITLEMENT_PUBLIC_KEYS).
# Generate a new keypair: the public key goes into engine/src/entitlement.rs,
# the private key goes here — NEVER commit the private key to the repository.
HOLOGRAM_ENTITLEMENT_SIGNING_KEY=<base64-encoded-32-byte-ed25519-private-key>

# === Logging ===
# RUST_LOG=info
# PYTHONUNBUFFERED=1
